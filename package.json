{
  "name": "haish-agent",
  "version": "0.1.0",
  "private": true,
  "description": "Haish desktop app with a local agent runtime.",
  "main": "dist-electron/main/main.js",
  "author": "Haish",
  "productName": "Haish",
  "type": "module",
  "scripts": {
    "dev": "tsc -p tsconfig.electron.json && electron .",
    "build": "tsc --noEmit && tsc -p tsconfig.electron.json",
    "build:runtime": "node scripts/build-runtime.mjs",
    "start": "electron .",
    "pack:mac": "npm run build && npm run build:runtime && electron-builder --mac dir",
    "dist:mac": "npm run build && npm run build:runtime && electron-builder --mac dmg zip",
    "check:mac-release": "node scripts/check-mac-release.mjs",
    "dist:mac:release": "npm run check:mac-release && npm run build && npm run build:runtime && electron-builder --mac dmg zip --config.forceCodeSigning=true",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit"
  },
  "build": {
    "appId": "com.haish.agent",
    "productName": "Haish",
    "artifactName": "Haish-${version}-${arch}.${ext}",
    "asar": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "app-web/**/*",
      "build/icon.png",
      "dist-electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/runtime/haish-agent-core",
        "to": "haish-agent-core",
        "filter": [
          "**/*",
          "!**/.git/**",
          "!**/.idea/**",
          "!**/.pytest_cache/**",
          "!**/__pycache__/**",
          "!**/*.pyc",
          "!**/*.pyo",
          "!**/.agent-world-web.log"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "hardenedRuntime": true,
      "entitlements": "entitlements/entitlements.mac.plist",
      "entitlementsInherit": "entitlements/entitlements.mac.inherit.plist",
      "signIgnore": [
        "/Contents/Resources/haish-agent-core/.*\\.py$"
      ],
      "notarize": true,
      "target": [
        "dmg",
        "zip"
      ]
    },
    "dmg": {
      "artifactName": "Haish-${version}-${arch}.${ext}"
    }
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.5.2",
    "concurrently": "^9.1.2",
    "lucide-react": "^1.23.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "wait-on": "^8.0.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1"
  },
  "overrides": {
    "@electron/osx-sign": {
      "isbinaryfile": "^5.0.7"
    }
  }
}
